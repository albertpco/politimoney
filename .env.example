# Required — get a free key at https://api.open.fec.gov/developers/
FEC_API_KEY=

# Required — get a free key at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# Optional — PostgreSQL for deep drill-down (not needed for most usage)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/politimoney"
# INGEST_DB_WRITE=true

# Optional — tune ingestion limits
# INGEST_CYCLE=2026
# INGEST_CANDIDATE_LIMIT=200
# INGEST_FARA_REGISTRANT_LIMIT=25
# INGEST_FEC_COMMITTEE_LIMIT=2000
# INGEST_FEC_CONTRIBUTION_LIMIT=25000
# INGEST_FEC_MAX_PAGES_PER_DATASET=500
# INGEST_FEC_CONTRIBUTION_PAGE_DELAY_MS=800
# INGEST_BULK_CYCLES=2024
# INGEST_BULK_BATCH_SIZE=5000

# Optional — protect the HTTP MCP endpoint
# MCP_BEARER_TOKEN=

# Optional — public feed export destination for R2/Cloudflare Pages workflows
# POLITIMONEY_FEED_OUT_DIR=dist/public-feed/latest
