{
  "name": "politimoney",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:dev": "vite --config cloudflare/vite.config.ts",
    "cf:build": "vite build --config cloudflare/vite.config.ts",
    "cf:preview": "vite preview --config cloudflare/vite.config.ts",
    "cf:check": "npm run feed:export && npm run cf:build",
    "start": "next start",
    "lint": "eslint",
    "ingest": "NODE_OPTIONS='--max-old-space-size=8192' tsx src/scripts/ingest.ts",
    "ingest:status": "tsx src/scripts/ingest.ts --status",
    "ingest:scheduler": "tsx src/scripts/ingest-scheduler.ts",
    "ingest:scheduler:once": "tsx src/scripts/ingest-scheduler.ts --once",
    "backfill:congress-spine": "tsx src/scripts/backfill-congress-spine.ts",
    "parse:bulk": "tsx src/scripts/parse-bulk-to-json.ts",
    "fetch:votes": "tsx src/scripts/fetch-votes.ts",
    "fetch:financials": "tsx src/scripts/fetch-financials.ts",
    "fetch:lobbying": "tsx src/scripts/fetch-lobbying.ts",
    "fetch:efilings": "tsx src/scripts/fetch-efilings.ts",
    "fetch:insider-trades": "tsx src/scripts/fetch-insider-trades.ts",
    "feed:export": "tsx src/scripts/export-public-feed.ts",
    "mcp:server": "tsx src/scripts/mcp-server.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^6.19.2",
    "@vitejs/plugin-react": "^5.1.2",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/yauzl": "^2.10.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.3.0",
    "vitest": "^3.2.4"
  }
}
